generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum RoomStatus {
  available
  occupied
  maintenance
}

enum BookingStatus {
  pending
  confirmed
  checked_in
  checked_out
  no_show
  cancelled
}

enum MealPlanCode {
  room_only
  half_board
  full_board
}

enum BookingSource {
  website
  admin_manual
}

enum PaymentStatus {
  unpaid
  paid
}

model RoomType {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String
  maxCapacity Int
  basePrice   Int
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms     Room[]
  mealPlans RoomTypeMealPlan[]
}

model MealPlan {
  id   String       @id @default(cuid())
  code MealPlanCode @unique
  name String

  adultPrice Int
  childPrice Int

  roomTypes RoomTypeMealPlan[]
  bookings  Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomTypeMealPlan {
  id         String @id @default(cuid())
  roomTypeId String
  mealPlanId String

  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@unique([roomTypeId, mealPlanId])
}

model Room {
  id     String     @id @default(cuid())
  number String     @unique
  floor  Int
  status RoomStatus @default(available)

  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)

  bookings Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id String @id @default(cuid())

  bookingGroupId String?

  roomId     String
  mealPlanId String?

  room     Room      @relation(fields: [roomId], references: [id], onDelete: Restrict)
  mealPlan MealPlan? @relation(fields: [mealPlanId], references: [id], onDelete: Restrict)

  startDate DateTime
  endDate   DateTime

  persons    Int
  adultMeals Int
  childMeals Int

  status BookingStatus @default(confirmed)

  guestName  String
  guestEmail String
  guestPhone String?
  notes      String?

  bookingSource BookingSource @default(admin_manual)
  paymentStatus PaymentStatus @default(unpaid)
  paymentNote   String?

  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?

  roomPrice     Int
  mealPlanPrice Int
  totalPrice    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingGroupId])
}

model Invoice {
  id String @id @default(cuid())

  number         String @unique
  bookingGroupId String @unique

  stripePaymentIntentId String?

  guestName  String
  guestEmail String

  totalPrice Int

  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([number])
  @@index([stripePaymentIntentId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("owner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SystemLog {
  id String @id @default(cuid())

  type    SystemLogType
  message String?

  bookingId      String?
  bookingGroupId String?
  metadata       Json?

  createdAt DateTime @default(now())
}

enum SystemLogType {
  website_booking_validated
  website_booking_failed
  admin_booking_created
  admin_booking_updated
  admin_booking_deleted
  booking_check_in
  booking_check_out
  booking_no_show
  booking_cancelled
}
